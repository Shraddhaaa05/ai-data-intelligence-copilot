# AI Data Intelligence Copilot v3.1
# Environment Configuration Example
# 
# IMPORTANT: Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to GitHub (it's in .gitignore)

# ============================================================================
# REQUIRED: Choose ONE LLM Provider (both are free)
# ============================================================================

# Option 1: Groq (Recommended - Fastest & Free with No Quota)
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_actual_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Google Gemini (Free tier available)
# Get free API key at: https://aistudio.google.com
GOOGLE_API_KEY=AIzaSy_your_actual_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# OPTIONAL: Model Training Settings
# ============================================================================

# Random seed for reproducibility
RANDOM_STATE=42

# Train/test split ratio (0.2 = 80% train, 20% test)
TEST_SIZE=0.2

# ============================================================================
# OPTIONAL: Streamlit Configuration
# ============================================================================

# Streamlit server settings
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ============================================================================
# OPTIONAL: Advanced Settings
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable experimental features
EXPERIMENTAL_FEATURES=false

# ============================================================================
# HOW TO USE:
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual API keys
# 3. Never commit .env to GitHub (it's in .gitignore)
# 4. The app will read from .env file automatically
# 5. If no API keys: app uses rule-based fallback (works but slower)

# ============================================================================
# GET FREE API KEYS:
# ============================================================================

# Groq (Fastest - Recommended)
# 1. Go to https://console.groq.com
# 2. Sign up (free)
# 3. Create API key in dashboard
# 4. Copy to GROQ_API_KEY above
# Note: FREE tier, NO quota limits, VERY fast

# Google Gemini
# 1. Go to https://aistudio.google.com
# 2. Create API key (free tier available)
# 3. Copy to GOOGLE_API_KEY above
# Note: FREE tier has request limits (~60 per minute)

# ============================================================================
